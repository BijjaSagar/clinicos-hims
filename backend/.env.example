APP_NAME=ClinicOS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_DOMAIN=clinic0s.com
APP_VERSION=1.0.0

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================
# DATABASE - MySQL
# =============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=clinicos
DB_USERNAME=root
DB_PASSWORD=

# =============================================
# CACHE & SESSION
# =============================================
BROADCAST_DRIVER=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# =============================================
# REDIS (Optional - for caching/queues)
# =============================================
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================
# MAIL - SMTP
# =============================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@clinic0s.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================
# AWS S3 (Optional - for file storage)
# =============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================
# WHATSAPP BUSINESS API
# =============================================
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_API_VERSION=v19.0
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# =============================================
# RAZORPAY (Payment Gateway)
# =============================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# =============================================
# CORS
# =============================================
CORS_ALLOWED_ORIGINS=https://clinic0s.com,https://www.clinic0s.com
CORS_ORIGIN_PATTERN=https://*.clinic0s.com

# =============================================
# PHOTO VAULT
# =============================================
PHOTO_VAULT_ENCRYPT_UPLOADS=false

# =============================================
# ABDM / AYUSHMAN BHARAT
# =============================================
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
ABDM_BASE_URL=https://healthidsbx.abdm.gov.in

# =============================================
# SANCTUM - SPA Auth
# =============================================
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:8000

# =============================================
# OPENAI / CLAUDE (AI Features)
# =============================================
# Secret must start with sk- or sk-proj-. EMR dictation calls whisper-1; if OpenAI returns 403 "does not have access to model whisper-1", enable Audio / Speech-to-text for that key's project (or use a key from another project) at platform.openai.com.
# If OpenAI returns 401 "Missing scopes: model.request", the key is restricted — use a standard key or add Model (model.request) scope to the restricted key.
OPENAI_API_KEY=
# Default: .env key is used first when set. Set true only if each clinic must override the server key (SaaS).
OPENAI_CLINIC_KEY_OVERRIDES_ENV=false
# Deprecated: if true, same as OPENAI_CLINIC_KEY_OVERRIDES_ENV=false
OPENAI_PREFER_ENV_KEY=false
ANTHROPIC_API_KEY=

# =============================================
# SENTRY (Error Monitoring)
# =============================================
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
